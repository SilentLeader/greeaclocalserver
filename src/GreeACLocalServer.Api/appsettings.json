{
    "Serilog": {
        "Using": [
            "Serilog.Sinks.Console"
        ],
        "MinimumLevel": "Information",
        "WriteTo": [
            {
                "Name": "Console",
                "Args": {
                    "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {ConnectionId:?}{OperationId:?} {ClientIPAddress} {Message:lj}{NewLine}{Exception}"
                }
            }
        ],
        "Enrich": [
            "FromLogContext",
            "WithThreadId"
        ],
        "Properties": {
            "Application": "GreeACHeartBeatServer"
        }
    },
    "Server": {
        "EnableUI": true,
        "EnableManagement": true
    },
    "DeviceManager": {
        "DeviceTimeoutMinutes": 60
    },
    "Kestrel": {
        "Endpoints": {
            "Http": {
                "Url": "http://*:5100"
            }
        }
    },
    "GreeServer": {
        "ServerOptions": {
            "DomainName": "local.server.name",
            "ExternalIp": "127.0.0.1",
            "TLSEnabled": true,
            "ListenIPAddresses": []
        },
        "EncryptionOptions": {
            "DefaultCryptoKey": "a3K8Bx%2r8Y7#xDh",
            "TLSCertificateAutoCreate": true,
            "TLSCertificatePath": "",
            "TLSCertificatePassword": ""
        }
    },
    "ForwardedHeaders": {
        "ForwardedForHeaderName": "X-Forwarded-For",
        "ForwardedProtoHeaderName": "X-Forwarded-Proto",
        "ForwardedHostHeaderName": "X-Forwarded-Host",
        "RequireHeaderSymmetry": false,
        "KnownProxies": [],
        "KnownNetworks": [],
        "AllowedHosts": []
    }
}